{
  "version": "1.0",
  "meta": {
    "info": "这是一个登录页面的UI设计DSL示例，包含一个登录卡片，卡片内有标题文本、用户名输入框、密码输入框和登录按钮。DSL定义了页面的结构、UI元素的属性、交互事件以及代码生成配置。"
  },
  "page": {
    "id": "login_page", // 当前页面名称
    "className": "LoginPage", // 生成c++后对应的类名
    "width": 450, // 页面宽度
    "height": 560, // 页面高度
    "background": "#FFFFFF" // 页面背景色
  },
  "ui": [ // 页面UI元素
    {
      "id": "loginCard", // ui元素id
      "name": "登录卡片", // ui元素名称
      "type": "ImagePanel", // ui元素类型 当前支持 ImagePanel, Text, Button, Edit, CheckBox, RadioButton, Slider, ProgressBar, ListView, ScrollView
      "rect": [
        75,
        91,
        300,
        378
      ], // ui元素位置和大小 [x, y, width, height]
      "asset": { // ui元素资源 
        "path": "assets/login_card_bg.png", // ui元素资源路径
        "format": "png", // ui元素资源格式
        "scaleMode": "center" // ui元素资源缩放模式 stretch, repeat, center
      },
      "codegen": {
        "targetComponent": "ImageLabel", // 生成c++代码后对应的组件类型
        "variableName": "m_loginCard", // 生成c++代码后对应的成员变量名称
      },
      "children": [ // 包含的子控件
        {
          "id": "titleText", // 子控件1的id
          "type": "Text", // 子控件1的类型
          "text": "WELCOME", // 子控件1的文本内容
          "ngv2Widget": "NMLabel", // ngv2对应的widget类型
          "rect": [
            58,
            43,
            184,
            40
          ], // 子控件1的位置和大小
          "style": { // 子控件1的样式
            "fontSize": 30, // 字体大小
            "letterSpacing": 4, // 字符间距
            "color": "#FFFFFF", // 字体颜色
            "align": "center" // 字体对齐方式 left, center, right
          },
          "codegen": {
            "targetComponent": "NMLabel", // 生成c++代码后对应的组件类型
            "variableName": "m_titleText" // 生成c++代码后对应的成员变量名称
          }
        },
        {
          "id": "usernameIcon",
          "type": "Icon",
          "rect": [
            14,
            11,
            16,
            16
          ],
          "asset": {
            "path": "assets/icon_user.svg",
            "format": "svg"
          },
          "style": {
            "color": "#FFFFFF"
          },
          "codegen": {
            "targetComponent": "ImageLabel", // 生成c++代码后对应的组件类型
            "variableName": "m_usernameIcon" // 生成c++代码后对应的成员变量名称
          }
        },
        {
          "id": "passwordIcon",
          "type": "Icon",
          "rect": [
            14,
            11,
            16,
            16
          ],
          "asset": {
            "path": "assets/icon_lock.svg",
            "format": "svg"
          },
          "style": {
            "color": "#FFFFFF"
          },
          "codegen": {
            "targetComponent": "ImageLabel",
            "variableName": "m_passwordIcon"
          }
        },
        {
          "id": "usernameEdit", // 子控件2的id
          "type": "Edit", // 子控件2的类型
          "text": "vincent_chow", // 子控件2的文本内容
          "placeholder": "请输入用户名", // 子控件2未输入时的占位符文本
          "ngv2Widget": "NMEdit", // ngv2对应的widget类型
          "rect": [
            28,
            123,
            244,
            40
          ], // 子控件2的位置和大小
          "style": { // 子控件2的样式
            "fontSize": 15, // 字体大小
            "color": "#FFFFFF", // 字体颜色
            "borderColor": "#FFFFFF", // 边框颜色
            "borderWidth": 1, // 边框宽度
            "radius": 4, // 圆角半径
            "paddingLeft": 40 // 左内边距
          },
          "codegen": {
            "targetComponent": "NMEdit", // 生成c++代码后对应的组件类型
            "variableName": "m_usernameEdit" // 生成c++代码后对应的成员变量名称
          }
        },
        {
          "id": "passwordEdit", // 子控件3的id
          "type": "Edit", // 子控件3的类型
          "inputMode": "password", // 子控件3的输入模式 password表示密码输入框，输入内容会以掩码显示
          "placeholder": "密码", // 子控件3未输入时的占位符文本
          "ngv2Widget": "NMEdit", // ngv2对应的widget类型
          "rect": [
            28,
            183,
            244,
            40
          ], // 子控件3的位置和大小
          "style": { // 子控件3的样式
            "fontSize": 15, // 字体大小
            "color": "#FFFFFF", // 字体颜色
            "borderColor": "#FFFFFF", // 边框颜色
            "borderWidth": 1, // 边框宽度
            "radius": 4, // 圆角半径
            "paddingLeft": 40 // 左内边距
          },
          "codegen": {
            "targetComponent": "NMEdit", // 生成c++代码后对应的组件类型
            "variableName": "m_passwordEdit" // 生成c++代码后对应的成员变量名称
          }
        },
        {
          "id": "loginButton",
          "type": "Button",
          "ngv2Widget": "NMButton",
          "text": "登 录",
          "rect": [
            28,
            248,
            244,
            40
          ],
          "style": {
            "fontSize": 16,
            "color": "#FFFFFF",
            "background": "#3294F6",
            "radius": 4
          },
          "codegen": {
            "targetComponent": "NMButton",
            "variableName": "m_loginButton"
          },  
          "events": {
            "click": "OnLoginClicked"
          }
        },
        {
          "id": "registerButton",
          "type": "Button",
          "text": "注册",
          "ngv2Widget": "NMButton",
          "rect": [
            28,
            308,
            244,
            40
          ],
          "style": {
            "fontSize": 16,
            "color": "#FFFFFF",
            "background": "#3294F6",
            "radius": 4
          },
          "events": {
            "click": "OnRegisterClicked"
          },
          "codegen": {
            "targetComponent": "NMButton",
            "variableName": "m_registerButton"
          }
        },
        {
          "id": "forgotPasswordButton",
          "type": "Button",
          "ngv2Widget": "NMButton",
          "text": "忘记密码",
          "rect": [
            28,
            368,
            244,
            40
          ],
          "style": {
            "fontSize": 16,
            "color": "#FFFFFF",
            "background": "#3294F6",
            "radius": 4
          },
          "events": {
            "click": "OnForgotPasswordClicked"
          },
          "codegen": {
            "targetComponent": "NMButton",
            "variableName": "m_forgotPasswordButton"
          }
        }
      ]
    }
  ],
  "assets": [
    {
      "id": "loginCardBg",
      "path": "assets/login_card_bg.png",
      "type": "image",
      "format": "png"
    }
  ]
}