{
  "version": "1.0",
  "meta": {
    "sourceType": "image",
    "sourceFile": "login.png"
  },
  "page": {
    "id": "login_page", // 当前页面名称
    "className": "LoginPage",   // 生成c++后对应的类名
    "width": 450, // 页面宽度
    "height": 560, // 页面高度
    "background": "#FFFFFF" // 页面背景色
  },
  "ui": [ // 页面UI元素
    {
      "id": "loginCard", // ui元素id
      "name": "登录卡片", // ui元素名称
      "type": "ImagePanel", // ui元素类型 当前支持 ImagePanel, Text, Button, Edit, CheckBox, RadioButton, Slider, ProgressBar, ListView, ScrollView
      "rect": [75, 91, 300, 378], // ui元素位置和大小 [x, y, width, height]
      "asset": { // ui元素资源 
        "path": "assets/login_card_bg.png", // ui元素资源路径
        "format": "png", // ui元素资源格式
        "scaleMode": "center" // ui元素资源缩放模式 stretch, repeat, center
      },
      "children": [ // 包含的子控件
        {
          "id": "titleText", // 子控件1的id
          "type": "Text", // 子控件1的类型
          "text": "WELCOME", // 子控件1的文本内容
          "rect": [58, 43, 184, 40], // 子控件1的位置和大小
          "style": { // 子控件1的样式
            "fontSize": 30, // 字体大小
            "letterSpacing": 4, // 字符间距
            "color": "#FFFFFF", // 字体颜色
            "align": "center" // 字体对齐方式 left, center, right
          }
        },
        {
          "id": "usernameEdit", // 子控件2的id
          "type": "Edit", // 子控件2的类型
          "text": "vincent_chow", // 子控件2的文本内容
          "placeholder": "请输入用户名", // 子控件2未输入时的占位符文本
          "rect": [28, 123, 244, 40], // 子控件2的位置和大小
          "style": { // 子控件2的样式
            "fontSize": 15, // 字体大小
            "color": "#FFFFFF", // 字体颜色
            "borderColor": "#FFFFFF", // 边框颜色
            "borderWidth": 1, // 边框宽度
            "radius": 4, // 圆角半径
            "paddingLeft": 40 // 左内边距
          }
        },
        {
          "id": "passwordEdit",
          "type": "Edit",
          "inputMode": "password",
          "placeholder": "密码",
          "rect": [28, 183, 244, 40],
          "style": {
            "fontSize": 15,
            "color": "#FFFFFF",
            "borderColor": "#FFFFFF",
            "borderWidth": 1,
            "radius": 4,
            "paddingLeft": 40
          }
        },
        {
          "id": "loginButton",
          "type": "Button",
          "text": "登 录",
          "rect": [28, 248, 244, 40],
          "style": {
            "fontSize": 16,
            "color": "#FFFFFF",
            "background": "#3294F6",
            "radius": 4
          },
          "events": {
            "click": "OnLoginClicked"
          }
        }
      ]
    }
  ],
  "interactions": [
    {
      "source": "loginButton",
      "event": "click",
      "handler": "OnLoginClicked"
    }
  ],
  "assets": [
    {
      "id": "loginCardBg",
      "path": "assets/login_card_bg.png",
      "type": "image",
      "format": "png"
    }
  ],
  "codegen": {
    "target": "cpp_custom_ui",
    "layoutMode": "absolute",
    "coordinate": "relative_to_parent",
    "stringEncoding": "utf8",
    "dynamicStrategy": "create_all_then_toggle_visible",
    "generateEventStubs": true,
    "generateStateMembers": true,
    "generateUpdateUIByState": true
  }
}